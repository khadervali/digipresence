# Prerendered routes live as real directories (e.g. /about/index.html).
# Serve them directly. This rule tries the prerendered static file first,
# then falls back to the SPA shell only for genuine client-side routes.
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1) If the requested path is a prerendered directory, serve its index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)/?$ $1/index.html [L]

  # 2) If a matching prerendered file exists at /<route>/index.html, serve it
  RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}index.html -f
  RewriteRule ^(.*)/?$ $1/index.html [L]

  # 3) SPA fallback for everything else (real client routes)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>
