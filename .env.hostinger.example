# Copy this file to .env.hostinger and fill your values.
# Do not commit .env.hostinger with real secrets.

# Required
HOSTINGER_HOST=your-server-hostname-or-ip
HOSTINGER_USER=your-ssh-user
HOSTINGER_APP_DIR=/home/your-user/apps/your-node-app
HOSTINGER_REPO=https://github.com/your-org/your-repo.git

# Optional
HOSTINGER_BRANCH=main
HOSTINGER_PORT=22
# HOSTINGER_SSH_KEY=~/.ssh/id_ed25519

# Optional node setup on server (empty = skip nvm)
# HOSTINGER_NODE_VERSION=20

# Optional deploy commands run on server inside HOSTINGER_APP_DIR
HOSTINGER_INSTALL_CMD=npm ci
HOSTINGER_BUILD_CMD=npm run build
# Example restart for PM2-managed Node app
HOSTINGER_RESTART_CMD=pm2 restart digipresence

# Optional hooks
# HOSTINGER_PRE_DEPLOY_CMD=echo preparing deploy
# HOSTINGER_POST_DEPLOY_CMD=echo deploy finished
